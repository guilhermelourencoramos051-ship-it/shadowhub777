    -- HITBOX EXPANDER
    if T.HitboxExp then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character then
                local pr = p.Character:FindFirstChild("HumanoidRootPart")
                if pr then pcall(function() pr.Size = Vector3.new(2 * C.HitboxSize, 2 * C.HitboxSize, C.HitboxSize) end) end
            end
        end
    end

    -- FLY
    if T.Fly and rt then
        pcall(function()
            if not FlyBV or not FlyBV.Parent then
                FlyBV = Instance.new("BodyVelocity", rt); FlyBV.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
            end
            if not FlyBG or not FlyBG.Parent then
                FlyBG = Instance.new("BodyGyro", rt); FlyBG.MaxTorque = Vector3.new(math.huge, math.huge, math.huge); FlyBG.D = 500
