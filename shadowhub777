    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)

    -- Hover effect nas abas
    btn.MouseEnter:Connect(function()
        if ActiveTab and ActiveTab.btn ~= btn then
            Tween(btn, TI(0.15), {BackgroundTransparency = 0.2, TextColor3 = TH.White})
        end
    end)
    btn.MouseLeave:Connect(function()
        if ActiveTab and ActiveTab.btn ~= btn then
            Tween(btn, TI(0.15), {BackgroundTransparency = 0.5, TextColor3 = TH.Dim})
        end
    end)

    -- Page (scroll frame)
    local page = Instance.new("ScrollingFrame", Content)
    page.Size = UDim2.new(1, 0, 1, 0)
    page.BackgroundTransparency = 1
    page.BorderSizePixel = 0
    page.ScrollBarThickness = 3
    page.ScrollBarImageColor3 = TH.Pur
    page.CanvasSize = UDim2.new(0, 0, 0, 0)
    page.AutomaticCanvasSize = Enum.AutomaticSize.Y
    page.Visible = false
    page.ZIndex = 52

    local pl = Instance.new("UIListLayout", page)
    pl.Padding = UDim.new(0, 4)
    pl.SortOrder = Enum.SortOrder.LayoutOrder
    pl.HorizontalAlignment = Enum.HorizontalAlignment.Center

    local pp = Instance.new("UIPadding", page)
    pp.PaddingTop = UDim.new(0, 6)
    pp.PaddingBottom = UDim.new(0, 6)
    pp.PaddingLeft = UDim.new(0, 6)
    pp.PaddingRight = UDim.new(0, 6)

    local td
    local function Select()
        if ActiveTab then
            ActiveTab.page.Visible = false
            Tween(ActiveTab.btn, TI(0.2), {
                BackgroundTransparency = 0.5,
                TextColor3 = TH.Dim
            })
        end
        ActiveTab = td
        page.Visible = true
        Tween(btn, TI(0.2), {
            BackgroundTransparency = 0,
            BackgroundColor3 = TH.Pur,
            TextColor3 = TH.White
        })
        -- Animar o indicador para baixo da aba clicada
        local pos = btn.AbsolutePosition.X - TabBar.AbsolutePosition.X
        Tween(TabIndicator, TI(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
            Position = UDim2.new(0, pos, 1, -2),
            Size = UDim2.new(0, btn.AbsoluteSize.X, 0, 2)
        })
    end
    btn.MouseButton1Click:Connect(Select)

    td = {btn = btn, page = page, select = Select}
    table.insert(Tabs, td)
    return btn, page
end

local function OpenFirst()
    if Tabs[1] and Tabs[1].select then Tabs[1].select() end
end

