local function Sld(par, txt, ord, mn, mx, def, cb)
    local f = Instance.new("Frame", par)
    f.Size = UDim2.new(1, 0, 0, 50); f.BackgroundColor3 = Color3.fromRGB(12, 8, 24)
    f.BorderSizePixel = 0; f.LayoutOrder = ord
    Instance.new("UICorner", f).CornerRadius = UDim.new(0, 7)
    local sk = Instance.new("UIStroke", f)
    sk.Color = Color3.fromRGB(40, 20, 70); sk.Thickness = 1; sk.Transparency = 0.3

    local lb = Instance.new("TextLabel", f)
    lb.Size = UDim2.new(1, -60, 0, 18); lb.Position = UDim2.new(0, 10, 0, 4)
    lb.BackgroundTransparency = 1; lb.Text = txt; lb.TextColor3 = TH.White
    lb.TextSize = 11; lb.Font = Enum.Font.Gotham; lb.TextXAlignment = Enum.TextXAlignment.Left

    local vl = Instance.new("TextLabel", f)
    vl.Size = UDim2.new(0, 50, 0, 18); vl.Position = UDim2.new(1, -58, 0, 4)
    vl.BackgroundTransparency = 1; vl.Text = tostring(def); vl.TextColor3 = TH.MagL
    vl.TextSize = 11; vl.Font = Enum.Font.GothamBold; vl.TextXAlignment = Enum.TextXAlignment.Right

    local tr = Instance.new("Frame", f)
    tr.Size = UDim2.new(1, -20, 0, 4); tr.Position = UDim2.new(0, 10, 0, 32)
    tr.BackgroundColor3 = Color3.fromRGB(28, 14, 50); tr.BorderSizePixel = 0
    Instance.new("UICorner", tr).CornerRadius = UDim.new(1, 0)

    local fi = Instance.new("Frame", tr)
    fi.Size = UDim2.new((def - mn) / (mx - mn), 0, 1, 0)
    fi.BackgroundColor3 = TH.Mag; fi.BorderSizePixel = 0
    Instance.new("UICorner", fi).CornerRadius = UDim.new(1, 0)
    local fg = Instance.new("UIGradient", fi)
    fg.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, TH.PurL),
        ColorSequenceKeypoint.new(1, TH.MagL),
    })

    local th2 = Instance.new("Frame", tr)
    th2.Size = UDim2.new(0, 12, 0, 12); th2.AnchorPoint = Vector2.new(0.5, 0.5)
    th2.Position = UDim2.new((def - mn) / (mx - mn), 0, 0.5, 0)
    th2.BackgroundColor3 = TH.MagL; th2.BorderSizePixel = 0; th2.ZIndex = 54
    Instance.new("UICorner", th2).CornerRadius = UDim.new(1, 0)
    local thGlow = Instance.new("Frame", th2)
    thGlow.Size = UDim2.new(1, 8, 1, 8); thGlow.AnchorPoint = Vector2.new(0.5, 0.5)
    thGlow.Position = UDim2.new(0.5, 0, 0.5, 0); thGlow.BackgroundColor3 = TH.Mag
    thGlow.BackgroundTransparency = 0.6; thGlow.BorderSizePixel = 0; thGlow.ZIndex = 53
    Instance.new("UICorner", thGlow).CornerRadius = UDim.new(1, 0)

    local function Upd(xPos)
        local tpX = tr.AbsolutePosition.X
        local tpW = tr.AbsoluteSize.X
        if tpW < 1 then return end
        local rel = math.clamp((xPos - tpX) / tpW, 0, 1)
        local val = math.floor(mn + rel * (mx - mn) + 0.5)
        fi.Size = UDim2.new(rel, 0, 1, 0)
        th2.Position = UDim2.new(rel, 0, 0.5, 0)
        vl.Text = tostring(val)
        cb(val)
    end

    -- ★ FIX: TextButton overlay para capturar arraste do slider
    local dragArea = Instance.new("TextButton", f)
    dragArea.Size = UDim2.new(1, -14, 0, 24)
    dragArea.Position = UDim2.new(0, 7, 0, 22)
    dragArea.BackgroundTransparency = 1; dragArea.Text = ""
    dragArea.ZIndex = 57; dragArea.AutoButtonColor = false

    local myDrag = false
    dragArea.MouseButton1Down:Connect(function()
        myDrag = true
        Upd(Mouse.X)
    end)
    UserInputService.InputChanged:Connect(function(input)
        if myDrag and input.UserInputType == Enum.UserInputType.MouseMovement then
            Upd(input.Position.X)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            myDrag = false
        end
    end)
end

