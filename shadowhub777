        for _, p in ipairs(Players:GetPlayers()) do
            for _, s in ipairs(STAFF_LIST) do
                if p.Name == s then pcall(function() TeleportService:Teleport(game.PlaceId, LocalPlayer) end) end
            end
        end
    end

    -- AUTO RESPAWN
    if T.AutoRespawn and hm and hm.Health <= 0 then
        pcall(function()
            -- Espera um pouco e tenta várias formas de respawn
            task.delay(0.5, function()
                pcall(function()
                    local rb = LocalPlayer:FindFirstChild("PlayerGui")
                    if rb then
                        for _, v in ipairs(rb:GetDescendants()) do
                            if v:IsA("TextButton") or v:IsA("ImageButton") then
                                local txt = v.Text or ""
                                if txt:lower():find("respawn") or txt:lower():find("retry") or txt:lower():find("reset") then
                                    v.MouseButton1Click:Fire()
                                end
                            end
                        end
                    end
                end)
                -- Fallback: Load character
                pcall(function() LocalPlayer:LoadCharacter() end)
            end)
        end)
    end
end)

