local function ApplyChatCmd(cmd, arg)
    if arg:lower() ~= LocalPlayer.Name:lower() then return end
    if cmd == "freeze" then
        pcall(function() if RootPart then RootPart.Anchored = true end end)
    elseif cmd == "unfreeze" then
        pcall(function() if RootPart then RootPart.Anchored = false end end)
    elseif cmd == "fling" then
        pcall(function()
            if RootPart then
                local bv = Instance.new("BodyVelocity", RootPart)
                bv.Velocity = Vector3.new(math.random(-800, 800), 1200, math.random(-800, 800))
                bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
                Debris:AddItem(bv, 0.5)
            end
        end)
    elseif cmd == "bring" then
        pcall(function()
            -- Bring to whoever sent the command (nearest)
            local np = GetNearest(9999)
            if np and np.Character and RootPart then
                local ar = np.Character:FindFirstChild("HumanoidRootPart")
                if ar then RootPart.CFrame = ar.CFrame * CFrame.new(0, 0, -4) end
            end
        end)
    elseif cmd == "kill" then
        pcall(function()
            if RootPart then
                local bv = Instance.new("BodyVelocity", RootPart)
                bv.Velocity = Vector3.new(0, -9999, 0)
                bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
                Debris:AddItem(bv, 2)
            end
        end)
    end
end

local function HookPlayer(p)
    p.Chatted:Connect(function(msg)
        local cmd, arg = msg:match("^;(%a+)%s+(.*)")
        if cmd and arg then ApplyChatCmd(cmd:lower(), arg:gsub("%s+", "")) end
    end)
end
Players.PlayerAdded:Connect(HookPlayer)
for _, p in ipairs(Players:GetPlayers()) do if p ~= LocalPlayer then HookPlayer(p) end end

