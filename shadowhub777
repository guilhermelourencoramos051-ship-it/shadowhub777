local function UpdateHUD(target, mode)
    if not target or not target.Character then HUD.Visible = false; return end
    HUD.Visible = true
    HTitle.Text = "🎯 [" .. mode .. "] " .. target.DisplayName

    -- Nome
    HInfoLabels[1].Text = "👤 Nome: " .. target.Name
    -- ID
    HInfoLabels[2].Text = "🆔 ID: " .. tostring(target.UserId)
    -- Conta (dias)
    HInfoLabels[3].Text = "📅 Conta: " .. tostring(target.AccountAge) .. " dias"

    -- Personagem (tenta ler do atributo ou de uma pasta comum no TSB)
    local charName = "N/A"
    pcall(function()
        charName = target:GetAttribute("SelectedCharacter")
            or target:GetAttribute("Character")
            or target:GetAttribute("CurrentCharacter")
            or "N/A"
        if charName == "N/A" then
            local ch = target.Character
            if ch then
                local charVal = ch:FindFirstChild("Character") or ch:FindFirstChild("CharacterName")
                    or ch:FindFirstChild("SelectedChar")
                if charVal and charVal:IsA("StringValue") then charName = charVal.Value end
            end
        end
        if charName == "N/A" then
            -- Tenta pelo folder de dados do jogador
            local pData = target:FindFirstChild("PlayerData") or target:FindFirstChild("Data")
            if pData then
                local cv = pData:FindFirstChild("Character") or pData:FindFirstChild("SelectedCharacter")
                if cv and cv:IsA("StringValue") then charName = cv.Value end
            end
        end
    end)
    HInfoLabels[4].Text = "🎮 Char: " .. tostring(charName)

    -- HP
    local hp, maxHp = 0, 100
    local tr2 = target.Character:FindFirstChild("HumanoidRootPart")
    local th2 = target.Character:FindFirstChildOfClass("Humanoid")
    if th2 then hp = math.floor(th2.Health); maxHp = math.floor(th2.MaxHealth) end
    HInfoLabels[5].Text = "❤️ HP: " .. hp .. "/" .. maxHp
    HInfoLabels[5].TextColor3 = hp > maxHp * 0.5 and TH.Green or (hp > maxHp * 0.25 and TH.Gold or TH.Red)

    -- Distância
    local dist = 0
    if tr2 and RootPart then dist = math.floor((RootPart.Position - tr2.Position).Magnitude) end
    HInfoLabels[6].Text = "📏 Dist: " .. dist .. "m"

    -- Kills e Streak (tenta ler leaderstats ou atributos)
    local kills, streak = "?", "?"
    pcall(function()
        local ls = target:FindFirstChild("leaderstats")
        if ls then
            local kv = ls:FindFirstChild("Kills") or ls:FindFirstChild("KOs") or ls:FindFirstChild("Kill")
            local sv = ls:FindFirstChild("Streak") or ls:FindFirstChild("WinStreak") or ls:FindFirstChild("Wins")
            if kv then kills = tostring(kv.Value) end
            if sv then streak = tostring(sv.Value) end
        end
        -- Tenta atributos
        if kills == "?" then
            local k = target:GetAttribute("Kills") or target:GetAttribute("KOs")
            if k then kills = tostring(k) end
        end
        if streak == "?" then
            local s = target:GetAttribute("Streak") or target:GetAttribute("WinStreak")
            if s then streak = tostring(s) end
        end
    end)
    HInfoLabels[7].Text = "🔥 Kills: " .. kills .. " | Streak: " .. streak

    -- Skin (tenta ler)
    local skin = "N/A"
    pcall(function()
        skin = target:GetAttribute("Skin") or target:GetAttribute("SelectedSkin")
            or target:GetAttribute("Costume") or "N/A"
        if skin == "N/A" then
            local ch = target.Character
            if ch then
                local sv = ch:FindFirstChild("Skin") or ch:FindFirstChild("SkinName")
                    or ch:FindFirstChild("Costume")
                if sv and sv:IsA("StringValue") then skin = sv.Value end
            end
        end
    end)
    HInfoLabels[8].Text = "👕 Skin: " .. tostring(skin)
end

