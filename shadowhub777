-- ── RenderStepped (alta prioridade) ──
RunService.RenderStepped:Connect(function()
    local ch = LocalPlayer.Character; if not ch then return end
    local hm = ch:FindFirstChildOfClass("Humanoid")
    local rt = ch:FindFirstChild("HumanoidRootPart")

    -- NO STUN
    if T.NoStun and rt and hm then
        pcall(function()
            for _, attr in ipairs({"Ragdoll", "Stunned", "IsStunned", "Stun"}) do
                ch:SetAttribute(attr, attr == "Stun" and 0 or false)
                hm:SetAttribute(attr, attr == "Stun" and 0 or false)
            end
            rt.Anchored = false
            for _, v in ipairs(ch:GetDescendants()) do
                if v:IsA("BallSocketConstraint") or (v:IsA("HingeConstraint") and v.Name == "Ragdoll") then
                    pcall(function() v:Destroy() end)
                end
            end
            local st = hm:GetState()
            if st == Enum.HumanoidStateType.FallingDown or st == Enum.HumanoidStateType.Ragdoll then
                hm:ChangeState(Enum.HumanoidStateType.GettingUp)
            end
        end)
    end

    -- ANTI-RAGDOLL
    if T.AntiRagdoll and hm then
        pcall(function()
            for _, v in ipairs(ch:GetDescendants()) do
                if v:IsA("BallSocketConstraint") then v.Enabled = false end
            end
        end)
    end

    -- AUTO BLOCK
    if T.AutoBlock and ch then
        pcall(function()
            ch:SetAttribute("IsBlocking", true)
            ch:SetAttribute("Blocking", true)
        end)
    end

    -- AUTO PARRY
    if T.AutoParry and ch then
        pcall(function()
            -- Detect incoming attacks and try to block at right timing
            local np, nd = GetNearest(15)
            if np and np.Character then
                local nph = np.Character:FindFirstChildOfClass("Humanoid")
                if nph then
                    local anim = nph:FindFirstChildOfClass("Animator")
                    if anim then
                        for _, t in ipairs(anim:GetPlayingAnimationTracks()) do
                            local n = t.Name:lower()
                            if n:find("punch") or n:find("attack") or n:find("hit") or n:find("m1") then
                                ch:SetAttribute("IsBlocking", true)
                                ch:SetAttribute("Blocking", true)
                                task.delay(0.3, function()
                                    if not T.AutoBlock then
                                        ch:SetAttribute("IsBlocking", false)
                                        ch:SetAttribute("Blocking", false)
                                    end
                                end)
                            end
                        end
                    end
                end
            end
        end)
    end

    -- NO KNOCKBACK
    if T.NoKnockback and rt then
        pcall(function()
            for _, v in ipairs(rt:GetChildren()) do
                if v:IsA("BodyVelocity") or v:IsA("BodyForce") then v:Destroy() end
            end
        end)
    end

    -- LOCK SPEED/JUMP
    if hm then
        if T.LockSpeed then pcall(function() hm.WalkSpeed = C.WalkSpeed end) end
        if T.LockJump then pcall(function() hm.JumpPower = C.JumpPower end) end
        if T.GodMode and hm.Health < hm.MaxHealth then hm.Health = hm.MaxHealth end
    end

    -- NOCLIP
    if T.Noclip then
        pcall(function()
            for _, part in ipairs(ch:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = false
                end
            end
        end)
    end

    -- MOON JUMP (segurar Space = subir)
    if T.MoonJump and rt and UserInputService:IsKeyDown(Enum.KeyCode.Space) then
        pcall(function()
            rt.Velocity = Vector3.new(rt.Velocity.X, 80, rt.Velocity.Z)
        end)
    end

    -- HITBOX EXPANDER
    if T.HitboxExp then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character then
                local pr = p.Character:FindFirstChild("HumanoidRootPart")
                if pr then
                    pcall(function()
                        pr.Size = Vector3.new(2 * C.HitboxSize, 2 * C.HitboxSize, C.HitboxSize)
                    end)
                end
            end
        end
    end

    -- FLY
    if T.Fly and rt then
        pcall(function()
            if not FlyBV or not FlyBV.Parent then
                FlyBV = Instance.new("BodyVelocity", rt)
                FlyBV.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
            end
            if not FlyBG or not FlyBG.Parent then
                FlyBG = Instance.new("BodyGyro", rt)
                FlyBG.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
                FlyBG.D = 500
            end
            local cam = Workspace.CurrentCamera
            local spd = C.FlySpeed
            local vel = Vector3.zero
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then vel = vel + cam.CFrame.LookVector * spd end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then vel = vel - cam.CFrame.LookVector * spd end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then vel = vel - cam.CFrame.RightVector * spd end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then vel = vel + cam.CFrame.RightVector * spd end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then vel = vel + Vector3.new(0, spd, 0) end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then vel = vel - Vector3.new(0, spd, 0) end
            FlyBV.Velocity = vel
            FlyBG.CFrame = cam.CFrame
        end)
    end

    -- ESP
    if T.ESP then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character then
                local pr = p.Character:FindFirstChild("HumanoidRootPart")
                local ph = p.Character:FindFirstChildOfClass("Humanoid")
                if pr and ph then
                    local bb = ESPObjs[p.Name]
                    if not bb or not bb.Parent then
                        bb = Instance.new("BillboardGui")
                        bb.Name = "SG_ESP_" .. p.Name
                        bb.Size = UDim2.new(0, 120, 0, 44)
                        bb.StudsOffset = Vector3.new(0, 3.5, 0)
                        bb.AlwaysOnTop = true
                        bb.Parent = pr
                        ESPObjs[p.Name] = bb

                        local nl = Instance.new("TextLabel", bb)
                        nl.Name = "N"
                        nl.Size = UDim2.new(1, 0, 0.55, 0)
                        nl.BackgroundTransparency = 1
                        nl.TextColor3 = TH.Mag
                        nl.Font = Enum.Font.GothamBold
                        nl.TextSize = 13
                        nl.Text = p.Name

                        local dl = Instance.new("TextLabel", bb)
                        dl.Name = "D"
                        dl.Size = UDim2.new(1, 0, 0.45, 0)
                        dl.Position = UDim2.new(0, 0, 0.55, 0)
                        dl.BackgroundTransparency = 1
                        dl.TextColor3 = TH.White
                        dl.Font = Enum.Font.Gotham
                        dl.TextSize = 10
                        dl.Text = "-- m"

                        local sb = Instance.new("SelectionBox", bb)
                        sb.Adornee = pr
                        sb.Color3 = TH.Mag
                        sb.LineThickness = 0.07
                        sb.SurfaceTransparency = 0.85
                        sb.SurfaceColor3 = TH.Pur
                    end
                    local dl = bb:FindFirstChild("D")
                    if dl and rt then
                        local d = math.floor((rt.Position - pr.Position).Magnitude)
                        dl.Text = d .. "m  HP:" .. math.floor(ph.Health)
                    end
                else
                    if ESPObjs[p.Name] then
                        pcall(function() ESPObjs[p.Name]:Destroy() end)
                        ESPObjs[p.Name] = nil
                    end
                end
            end
        end
    end
end)

-- ── Heartbeat (Arena, KillAura, Awakening, AutoLeave, TP Behind, HUD) ──
RunService.Heartbeat:Connect(function()
    local ch = LocalPlayer.Character; if not ch then return end
    local hm = ch:FindFirstChildOfClass("Humanoid")
    local rt = ch:FindFirstChild("HumanoidRootPart")

    -- INFINITE DASH
    if T.InfiniteDash and ch then
        pcall(function()
            for _, k in ipairs({"DashCooldown", "FrontDashCD", "BackDashCD", "SideDashCD", "DashCD"}) do
                ch:SetAttribute(k, 0)
                if hm then hm:SetAttribute(k, 0) end
            end
        end)
    end

    -- ARENA SUB
    if T.ArenaSub and ArenaTarget and ArenaTarget.Character then
        local tr = ArenaTarget.Character:FindFirstChild("HumanoidRootPart")
        if tr and rt then
            pcall(function()
                rt.CFrame = CFrame.new(tr.Position.X, tr.Position.Y - C.ArenaDepth, tr.Position.Z)
            end)
        end
        local th = ArenaTarget.Character:FindFirstChildOfClass("Humanoid")
        HUD.Visible = true
        HTitle.Text = "🎯 [SUB] " .. ArenaTarget.Name
        if th and tr and rt then
            HInfo.Text = string.format("HP: %d/%d  Dist: %dm",
                math.floor(th.Health), math.floor(th.MaxHealth),
                math.floor((rt.Position - tr.Position).Magnitude))
        end
    else
        if not T.ArenaDeitado then HUD.Visible = false end
    end

    -- ARENA DEITADO
    if T.ArenaDeitado and ArenaTarget and ArenaTarget.Character then
        local tr = ArenaTarget.Character:FindFirstChild("HumanoidRootPart")
        if tr and rt then
            pcall(function()
                rt.CFrame = CFrame.new(tr.Position.X, tr.Position.Y - C.ArenaDepth, tr.Position.Z)
                    * CFrame.Angles(math.rad(90), 0, 0)
            end)
        end
        local th = ArenaTarget.Character:FindFirstChildOfClass("Humanoid")
        HUD.Visible = true
        HTitle.Text = "🎯 [DEITADO] " .. ArenaTarget.Name
        if th and tr and rt then
            HInfo.Text = string.format("HP: %d/%d  Dist: %dm",
                math.floor(th.Health), math.floor(th.MaxHealth),
                math.floor((rt.Position - tr.Position).Magnitude))
        end
    end

    -- KILL AURA
    if T.KillAura and rt then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character then
                local pr = p.Character:FindFirstChild("HumanoidRootPart")
                local ph = p.Character:FindFirstChildOfClass("Humanoid")
                if pr and ph and ph.Health > 0 and (rt.Position - pr.Position).Magnitude <= C.KillAuraRange then
                    pcall(function()
                        local bv = Instance.new("BodyVelocity", pr)
                        bv.Velocity = (pr.Position - rt.Position).Unit * 90 + Vector3.new(0, 25, 0)
                        bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
                        Debris:AddItem(bv, 0.1)
                    end)
                end
            end
        end
    end

    -- AUTO AWAKENING
    if T.AutoAwakening and ch then
        pcall(function()
            local e = ch:GetAttribute("Energy") or ch:GetAttribute("Awakening") or 0
            local m = ch:GetAttribute("MaxEnergy") or ch:GetAttribute("MaxAwakening") or 100
            if e >= m then PressKey(Enum.KeyCode.G) end
        end)
    end

    -- TP BEHIND ENEMY (auto — mantém atrás do inimigo mais próximo)
    if T.TPBehind and rt then
        local np = GetNearest(50)
        if np and np.Character then
            local r = np.Character:FindFirstChild("HumanoidRootPart")
            if r then
                pcall(function()
                    rt.CFrame = r.CFrame * CFrame.new(0, 0, 3)
                end)
            end
        end
    end

    -- AUTO LEAVE
    if T.AutoLeave then
        for _, p in ipairs(Players:GetPlayers()) do
            for _, s in ipairs(STAFF_LIST) do
                if p.Name == s then
                    pcall(function() TeleportService:Teleport(game.PlaceId, LocalPlayer) end)
                end
            end
        end
    end
end)

