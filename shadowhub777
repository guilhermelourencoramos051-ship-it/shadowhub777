local function DDown(par, txt, ord, optsFn, cb)
    local f = Instance.new("Frame", par)
    f.Size = UDim2.new(1, 0, 0, 34)
    f.BackgroundColor3 = Color3.fromRGB(12, 8, 24)
    f.BorderSizePixel = 0
    f.LayoutOrder = ord
    f.ClipsDescendants = false
    Instance.new("UICorner", f).CornerRadius = UDim.new(0, 7)
    local sk = Instance.new("UIStroke", f)
    sk.Color = Color3.fromRGB(40, 20, 70)
    sk.Thickness = 1
    sk.Transparency = 0.3

    local lb = Instance.new("TextLabel", f)
    lb.Size = UDim2.new(0.5, 0, 1, 0)
    lb.Position = UDim2.new(0, 10, 0, 0)
    lb.BackgroundTransparency = 1
    lb.Text = txt
    lb.TextColor3 = TH.White
    lb.TextSize = 11
    lb.Font = Enum.Font.Gotham
    lb.TextXAlignment = Enum.TextXAlignment.Left

    local sel = Instance.new("TextButton", f)
    sel.Size = UDim2.new(0.46, 0, 0, 24)
    sel.Position = UDim2.new(0.52, 0, 0.5, -12)
    sel.BackgroundColor3 = TH.BG3
    sel.BorderSizePixel = 0
    sel.Text = "Selecionar ▾"
    sel.TextColor3 = TH.Dim
    sel.TextSize = 10
    sel.Font = Enum.Font.Gotham
    Instance.new("UICorner", sel).CornerRadius = UDim.new(0, 5)

    local dd = Instance.new("Frame", f)
    dd.Size = UDim2.new(0.46, 0, 0, 0)
    dd.Position = UDim2.new(0.52, 0, 1, 3)
    dd.BackgroundColor3 = TH.BG3
    dd.BorderSizePixel = 0
    dd.ClipsDescendants = true
    dd.ZIndex = 300
    dd.Visible = false
    Instance.new("UICorner", dd).CornerRadius = UDim.new(0, 5)
    Instance.new("UIListLayout", dd).SortOrder = Enum.SortOrder.LayoutOrder

    local open = false
    sel.MouseButton1Click:Connect(function()
        open = not open
        if open then
            for _, c in ipairs(dd:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
            local opts = optsFn()
            for i, o in ipairs(opts) do
                local it = Instance.new("TextButton", dd)
                it.Size = UDim2.new(1, 0, 0, 22)
                it.BackgroundColor3 = Color3.fromRGB(18, 12, 38)
                it.BorderSizePixel = 0
                it.Text = o
                it.TextColor3 = TH.White
                it.TextSize = 10
                it.Font = Enum.Font.Gotham
                it.LayoutOrder = i
                it.ZIndex = 301
                it.MouseButton1Click:Connect(function()
                    sel.Text = o .. " ▾"
                    dd.Visible = false
                    dd.Size = UDim2.new(0.46, 0, 0, 0)
                    open = false
                    cb(o)
                end)
            end
            dd.Size = UDim2.new(0.46, 0, 0, #opts * 22)
            dd.Visible = true
        else
            dd.Visible = false
            dd.Size = UDim2.new(0.46, 0, 0, 0)
        end
    end)
end

