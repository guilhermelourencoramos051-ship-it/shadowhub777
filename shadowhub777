                        local nl = Instance.new("TextLabel", bb); nl.Name = "N"
                        nl.Size = UDim2.new(1, 0, 0.55, 0); nl.BackgroundTransparency = 1
                        nl.TextColor3 = TH.Mag; nl.Font = Enum.Font.GothamBold; nl.TextSize = 13; nl.Text = p.Name
                        local dl = Instance.new("TextLabel", bb); dl.Name = "D"
                        dl.Size = UDim2.new(1, 0, 0.45, 0); dl.Position = UDim2.new(0, 0, 0.55, 0)
                        dl.BackgroundTransparency = 1; dl.TextColor3 = TH.White
                        dl.Font = Enum.Font.Gotham; dl.TextSize = 10; dl.Text = "-- m"
                        local sb = Instance.new("SelectionBox", bb); sb.Adornee = pr
                        sb.Color3 = TH.Mag; sb.LineThickness = 0.07; sb.SurfaceTransparency = 0.85; sb.SurfaceColor3 = TH.Pur
