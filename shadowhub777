-- ── TOGGLE ──
-- [CUSTOM] Card BG: mude Color3.fromRGB(12, 8, 24) para outra cor
-- [CUSTOM] Cor do toggle ON: mude TH.Mag no Tween
-- [CUSTOM] Cor do ponto indicador: mude TH.Green (ON) e Muted (OFF)
-- [CUSTOM] Tamanho do switch: mude o Size do bg (40x18 default)
local function Tog(par, txt, ord, cb)
    local f = Instance.new("Frame", par)
    f.Size = UDim2.new(1, 0, 0, 34)
    f.BackgroundColor3 = Color3.fromRGB(12, 8, 24)
    f.BorderSizePixel = 0
    f.LayoutOrder = ord
    Instance.new("UICorner", f).CornerRadius = UDim.new(0, 7)
    local sk = Instance.new("UIStroke", f)
    sk.Color = Color3.fromRGB(40, 20, 70)
    sk.Thickness = 1
    sk.Transparency = 0.3

    local lb = Instance.new("TextLabel", f)
    lb.Size = UDim2.new(1, -60, 1, 0)
    lb.Position = UDim2.new(0, 10, 0, 0)
    lb.BackgroundTransparency = 1
    lb.Text = txt
    lb.TextColor3 = TH.White
    lb.TextSize = 11
    lb.Font = Enum.Font.Gotham
    lb.TextXAlignment = Enum.TextXAlignment.Left

    -- Dot indicador
    local dot = Instance.new("Frame", f)
    dot.Size = UDim2.new(0, 5, 0, 5)
    dot.Position = UDim2.new(0, 3, 0.5, -2)
    dot.BackgroundColor3 = TH.Muted
    dot.BorderSizePixel = 0
    Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)

    -- Switch background
    local bg = Instance.new("Frame", f)
    bg.Size = UDim2.new(0, 40, 0, 18)
    bg.Position = UDim2.new(1, -50, 0.5, -9)
    bg.BackgroundColor3 = Color3.fromRGB(28, 14, 50)
    bg.BorderSizePixel = 0
    Instance.new("UICorner", bg).CornerRadius = UDim.new(1, 0)

    -- Knob
    local kn = Instance.new("Frame", bg)
    kn.Size = UDim2.new(0, 14, 0, 14)
    kn.Position = UDim2.new(0, 2, 0.5, -7)
    kn.BackgroundColor3 = Color3.fromRGB(80, 45, 130)
    kn.BorderSizePixel = 0
    Instance.new("UICorner", kn).CornerRadius = UDim.new(1, 0)

    local on = false
    local function Set(s)
        on = s
        -- [CUSTOM] Velocidade da animação: mude 0.2 (mais rápido = menor)
        Tween(bg, TI(0.2), {BackgroundColor3 = s and TH.Mag or Color3.fromRGB(28, 14, 50)})
        Tween(kn, TI(0.2, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            BackgroundColor3 = s and TH.White or Color3.fromRGB(80, 45, 130),
            Position = s and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7)
        })
        Tween(dot, TI(0.2), {BackgroundColor3 = s and TH.Green or TH.Muted})
        Tween(sk, TI(0.2), {Color = s and TH.Mag or Color3.fromRGB(40, 20, 70)})
        cb(s)
    end

    -- Hover effect no card
    f.MouseEnter:Connect(function()
        Tween(f, TI(0.15), {BackgroundColor3 = Color3.fromRGB(18, 12, 35)})
    end)
    f.MouseLeave:Connect(function()
        Tween(f, TI(0.15), {BackgroundColor3 = Color3.fromRGB(12, 8, 24)})
    end)

    f.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then Set(not on) end
    end)
    return f, Set
end

-- ── SLIDER ──
-- [CUSTOM] Altura do slider card: mude o 50 em f.Size
-- [CUSTOM] Cor da barra preenchida: mude TH.Mag no fill e gradient
-- [CUSTOM] Cor do thumb (bolinha): mude TH.PurL
local function Sld(par, txt, ord, mn, mx, def, cb)
    local f = Instance.new("Frame", par)
    f.Size = UDim2.new(1, 0, 0, 50)
    f.BackgroundColor3 = Color3.fromRGB(12, 8, 24)
    f.BorderSizePixel = 0
    f.LayoutOrder = ord
    Instance.new("UICorner", f).CornerRadius = UDim.new(0, 7)
    local sk = Instance.new("UIStroke", f)
    sk.Color = Color3.fromRGB(40, 20, 70)
    sk.Thickness = 1
    sk.Transparency = 0.3

    local lb = Instance.new("TextLabel", f)
    lb.Size = UDim2.new(1, -60, 0, 18)
    lb.Position = UDim2.new(0, 10, 0, 4)
    lb.BackgroundTransparency = 1
    lb.Text = txt
    lb.TextColor3 = TH.White
    lb.TextSize = 11
    lb.Font = Enum.Font.Gotham
    lb.TextXAlignment = Enum.TextXAlignment.Left

    local vl = Instance.new("TextLabel", f)
    vl.Size = UDim2.new(0, 50, 0, 18)
    vl.Position = UDim2.new(1, -58, 0, 4)
    vl.BackgroundTransparency = 1
    vl.Text = tostring(def)
    vl.TextColor3 = TH.MagL
    vl.TextSize = 11
    vl.Font = Enum.Font.GothamBold
    vl.TextXAlignment = Enum.TextXAlignment.Right

    local tr = Instance.new("Frame", f)
    tr.Size = UDim2.new(1, -20, 0, 4)
    tr.Position = UDim2.new(0, 10, 0, 32)
    tr.BackgroundColor3 = Color3.fromRGB(28, 14, 50)
    tr.BorderSizePixel = 0
    Instance.new("UICorner", tr).CornerRadius = UDim.new(1, 0)

    local fi = Instance.new("Frame", tr)
    fi.Size = UDim2.new((def - mn) / (mx - mn), 0, 1, 0)
    fi.BackgroundColor3 = TH.Mag
    fi.BorderSizePixel = 0
    Instance.new("UICorner", fi).CornerRadius = UDim.new(1, 0)
    -- Gradiente na barra do slider
    local fg = Instance.new("UIGradient", fi)
    fg.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, TH.PurL),
        ColorSequenceKeypoint.new(1, TH.MagL),
    })

    -- Thumb com glow
    local th2 = Instance.new("Frame", tr)
    th2.Size = UDim2.new(0, 12, 0, 12)
    th2.AnchorPoint = Vector2.new(0.5, 0.5)
    th2.Position = UDim2.new((def - mn) / (mx - mn), 0, 0.5, 0)
    th2.BackgroundColor3 = TH.MagL
    th2.BorderSizePixel = 0
    th2.ZIndex = 54
    Instance.new("UICorner", th2).CornerRadius = UDim.new(1, 0)
    -- Mini glow no thumb
    local thGlow = Instance.new("Frame", th2)
    thGlow.Size = UDim2.new(1, 8, 1, 8)
    thGlow.AnchorPoint = Vector2.new(0.5, 0.5)
    thGlow.Position = UDim2.new(0.5, 0, 0.5, 0)
    thGlow.BackgroundColor3 = TH.Mag
    thGlow.BackgroundTransparency = 0.6
    thGlow.BorderSizePixel = 0
    thGlow.ZIndex = 53
    Instance.new("UICorner", thGlow).CornerRadius = UDim.new(1, 0)

    local sl = false
    local function Upd(pos)
        local rel = math.clamp((pos.X - tr.AbsolutePosition.X) / tr.AbsoluteSize.X, 0, 1)
        local val = math.floor(mn + rel * (mx - mn) + 0.5)
        fi.Size = UDim2.new(rel, 0, 1, 0)
        th2.Position = UDim2.new(rel, 0, 0.5, 0)
        vl.Text = tostring(val)
        cb(val)
    end
    tr.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then sl = true; Upd(i.Position) end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if sl and i.UserInputType == Enum.UserInputType.MouseMovement then Upd(i.Position) end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then sl = false end
    end)
end

-- ── BOTÃO ──
-- [CUSTOM] Cor padrão: mude col (parâmetro)
-- [CUSTOM] Hover glow: mude TH.MagL na animação de hover
-- [CUSTOM] Altura: mude o 32 em b.Size
local function Btn(par, txt, ord, cb, col)
    col = col or TH.Pur
    local b = Instance.new("TextButton", par)
    b.Size = UDim2.new(1, 0, 0, 32)
    b.BackgroundColor3 = col
    b.BorderSizePixel = 0
    b.Text = txt
    b.TextColor3 = TH.White
    b.TextSize = 12
    b.Font = Enum.Font.GothamBold
    b.LayoutOrder = ord
    b.AutoButtonColor = false
    Instance.new("UICorner", b).CornerRadius = UDim.new(0, 7)
    -- Gradiente sutil no botão
    local bg = Instance.new("UIGradient", b)
    bg.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 255, 255)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(200, 200, 200)),
    })
    bg.Rotation = 90

    b.MouseEnter:Connect(function()
        Tween(b, TI(0.15), {BackgroundColor3 = TH.MagL})
    end)
    b.MouseLeave:Connect(function()
        Tween(b, TI(0.15), {BackgroundColor3 = col})
    end)
    b.MouseButton1Click:Connect(function()
        -- Click flash
        Tween(b, TI(0.08), {BackgroundColor3 = TH.White})
        task.delay(0.12, function()
            Tween(b, TI(0.15), {BackgroundColor3 = col})
        end)
        cb()
    end)
    return b
end

