local Tabs = {}; local ActiveTab = nil

local function MakeTab(icon, ord)
    local btn = Instance.new("TextButton", TabBar)
    btn.Size = UDim2.new(0, 38, 0, 24)
    btn.BackgroundColor3 = TH.BG3; btn.BackgroundTransparency = 0.5
    btn.BorderSizePixel = 0; btn.Text = icon; btn.TextSize = 13
    btn.Font = Enum.Font.GothamBold; btn.TextColor3 = TH.Dim
    btn.LayoutOrder = ord; btn.ZIndex = 52; btn.AutoButtonColor = false
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)

    btn.MouseEnter:Connect(function()
        if not ActiveTab or ActiveTab.btn ~= btn then
            Tween(btn, TI(0.15), {BackgroundTransparency = 0.2, TextColor3 = TH.White})
        end
    end)
    btn.MouseLeave:Connect(function()
        if not ActiveTab or ActiveTab.btn ~= btn then
            Tween(btn, TI(0.15), {BackgroundTransparency = 0.5, TextColor3 = TH.Dim})
        end
    end)

    local page = Instance.new("ScrollingFrame", Content)
    page.Size = UDim2.new(1, 0, 1, 0); page.BackgroundTransparency = 1
    page.BorderSizePixel = 0; page.ScrollBarThickness = 3
    page.ScrollBarImageColor3 = TH.Pur; page.CanvasSize = UDim2.new(0, 0, 0, 0)
    page.AutomaticCanvasSize = Enum.AutomaticSize.Y; page.Visible = false; page.ZIndex = 52
    local pl = Instance.new("UIListLayout", page); pl.Padding = UDim.new(0, 4)
    pl.SortOrder = Enum.SortOrder.LayoutOrder; pl.HorizontalAlignment = Enum.HorizontalAlignment.Center
    local pp = Instance.new("UIPadding", page)
    pp.PaddingTop = UDim.new(0, 6); pp.PaddingBottom = UDim.new(0, 6)
    pp.PaddingLeft = UDim.new(0, 6); pp.PaddingRight = UDim.new(0, 6)

    local td
    local function Select()
        if ActiveTab then
            ActiveTab.page.Visible = false
            Tween(ActiveTab.btn, TI(0.2), {BackgroundTransparency = 0.5, TextColor3 = TH.Dim})
        end
        ActiveTab = td; page.Visible = true
        Tween(btn, TI(0.2), {BackgroundTransparency = 0, BackgroundColor3 = TH.Pur, TextColor3 = TH.White})
        local pos = btn.AbsolutePosition.X - TabBar.AbsolutePosition.X
        Tween(TabIndicator, TI(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
            Position = UDim2.new(0, 6 + pos, 0, 66),
            Size = UDim2.new(0, btn.AbsoluteSize.X, 0, 2)
        })
    end
    btn.MouseButton1Click:Connect(Select)
    td = {btn = btn, page = page, select = Select}
    table.insert(Tabs, td)
    return page
end

local function OpenFirst()
    if Tabs[1] and Tabs[1].select then Tabs[1].select() end
end

