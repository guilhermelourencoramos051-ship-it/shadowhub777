RunService.Heartbeat:Connect(function()
    local ch = LocalPlayer.Character; if not ch then return end
    local hm = ch:FindFirstChildOfClass("Humanoid")
    local rt = ch:FindFirstChild("HumanoidRootPart")

    -- INFINITE DASH
    if T.InfiniteDash and ch then
        pcall(function()
            for _, k in ipairs({"DashCooldown", "FrontDashCD", "BackDashCD", "SideDashCD", "DashCD"}) do
                ch:SetAttribute(k, 0); if hm then hm:SetAttribute(k, 0) end
            end
        end)
    end

    -- ARENA SUB
    if T.ArenaSub and ArenaTarget and ArenaTarget.Character then
        local tr = ArenaTarget.Character:FindFirstChild("HumanoidRootPart")
        if tr and rt then
            pcall(function() rt.CFrame = CFrame.new(tr.Position.X, tr.Position.Y - C.ArenaDepth, tr.Position.Z) end)
        end
        UpdateHUD(ArenaTarget, "SUB")
    elseif not T.ArenaDeitado then
        HUD.Visible = false
    end

    -- ARENA DEITADO
    if T.ArenaDeitado and ArenaTarget and ArenaTarget.Character then
        local tr = ArenaTarget.Character:FindFirstChild("HumanoidRootPart")
        if tr and rt then
            pcall(function()
                rt.CFrame = CFrame.new(tr.Position.X, tr.Position.Y - C.ArenaDepth, tr.Position.Z)
                    * CFrame.Angles(math.rad(90), 0, 0)
            end)
        end
        UpdateHUD(ArenaTarget, "DEITADO")
    end

    -- KILL AURA
    if T.KillAura and rt then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character then
                local pr = p.Character:FindFirstChild("HumanoidRootPart")
                local ph = p.Character:FindFirstChildOfClass("Humanoid")
                if pr and ph and ph.Health > 0 and (rt.Position - pr.Position).Magnitude <= C.KillAuraRange then
                    pcall(function()
                        local bv = Instance.new("BodyVelocity", pr)
                        bv.Velocity = (pr.Position - rt.Position).Unit * 90 + Vector3.new(0, 25, 0)
                        bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge); Debris:AddItem(bv, 0.1)
                    end)
