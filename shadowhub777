-- ============================================================
-- [CUSTOM] ✨ EFEITO DE GLOW (brilho neon atrás de elementos)
-- ============================================================
-- Esta função cria um "brilho" colorido atrás de qualquer Frame.
-- Parâmetros:
--   parent  = onde colocar o glow
--   color   = cor do brilho (ex: TH.Mag)
--   size    = expansão do brilho em pixels (ex: 30)
--   transp  = transparência (0 = sólido, 0.95 = quase invisível)
--
-- [CUSTOM] Para glow mais forte: diminua transp (ex: 0.6)
-- [CUSTOM] Para glow maior: aumente size (ex: 50)
-- [CUSTOM] Para glow pulsante, veja a função PulseGlow abaixo.
-- ============================================================
local function MakeGlow(parent, color, size, transp)
    local g = Instance.new("Frame", parent)
    g.Name = "Glow"
    g.AnchorPoint = Vector2.new(0.5, 0.5)
    g.Position = UDim2.new(0.5, 0, 0.5, 0)
    g.Size = UDim2.new(1, size, 1, size)
    g.BackgroundColor3 = color
    g.BackgroundTransparency = transp or 0.85
    g.BorderSizePixel = 0
    g.ZIndex = parent.ZIndex - 1
    Instance.new("UICorner", g).CornerRadius = UDim.new(0, 20)
    return g
end

-- [CUSTOM] Glow que pulsa (respira) automaticamente
-- speed = velocidade em segundos (2 = lento e elegante, 0.5 = rápido)
local function PulseGlow(glow, speed, minT, maxT)
    speed = speed or 2; minT = minT or 0.75; maxT = maxT or 0.92
    task.spawn(function()
        while glow and glow.Parent do
            Tween(glow, TI(speed, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {BackgroundTransparency = maxT})
            task.wait(speed)
            Tween(glow, TI(speed, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {BackgroundTransparency = minT})
            task.wait(speed)
        end
    end)
end

