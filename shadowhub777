StatusBar.Position = UDim2.new(0, 0, 1, -1)
StatusBar.BackgroundColor3 = TH.Mag
StatusBar.BackgroundTransparency = 0.4
StatusBar.BorderSizePixel = 0
StatusBar.ZIndex = 52

-- Animated gradient na barra de status
local sbGrad = Instance.new("UIGradient", StatusBar)
sbGrad.Color = ColorSequence.new({
    ColorSequenceKeypoint.new(0, TH.Pur),
    ColorSequenceKeypoint.new(0.5, TH.MagL),
    ColorSequenceKeypoint.new(1, TH.Pur),
})
-- Animar rotação do gradiente
task.spawn(function()
    local rot = 0
    while StatusBar and StatusBar.Parent do
        rot = (rot + 1) % 360
        sbGrad.Rotation = rot
        task.wait(0.03)
    end
end)

